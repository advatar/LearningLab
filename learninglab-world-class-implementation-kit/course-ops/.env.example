# GitHub
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com

# Google Classroom auth
#
# For one-shot runs, you can export a short-lived access token instead:
#   GOOGLE_ACCESS_TOKEN="$(gcloud auth print-access-token)"
GOOGLE_ACCESS_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_CLASSROOM_API_BASE=https://classroom.googleapis.com

# Optional overrides
GOOGLE_SCOPES=https://www.googleapis.com/auth/classroom.coursework.students https://www.googleapis.com/auth/classroom.rosters.readonly https://www.googleapis.com/auth/classroom.profile.emails https://www.googleapis.com/auth/classroom.courses.readonly
